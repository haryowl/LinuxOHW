# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for shell scripts
*.sh text eol=lf

# Force LF line endings for JavaScript files
*.js text eol=lf

# Force LF line endings for JSON files
*.json text eol=lf

# Force LF line endings for Markdown files
*.md text eol=lf

# Force LF line endings for configuration files
*.conf text eol=lf
*.config text eol=lf

# Binary files
*.sqlite binary
*.sqlite3 binary
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary


